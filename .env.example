# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=Homeschool API
DEBUG=True
ENVIRONMENT=development

# ============================================
# SERVER CONFIGURATION
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# SECURITY
# ============================================
# IMPORTANT: Generate a secure random secret key for production!
# Run this command to generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-CHANGE-THIS-IN-PRODUCTION

# ============================================
# GOOGLE OAUTH CREDENTIALS
# ============================================
# Get these from: https://console.cloud.google.com/apis/credentials
# 
# Steps:
# 1. Create a new project or select existing
# 2. Enable "Google+ API" or "Google Identity Services"
# 3. Go to Credentials → Create Credentials → OAuth 2.0 Client ID
# 4. Configure OAuth consent screen (add test users if in testing mode)
# 5. Create OAuth Client ID (Web application type)
# 6. Copy the Client ID below
#
# Example: 123456789-abc123def456.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional - not currently used for ID token verification, but may be needed later
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string with PostGIS support
# Format: postgresql://username:password@host:port/database_name
#
# Local development example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/homeschool_map
#
# Docker example:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/homeschool_map
#
# Production example (use strong password!):
# DATABASE_URL=postgresql://prod_user:STRONG_PASSWORD@your-db-host.com:5432/homeschool_prod

# Database connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ============================================
# NOTES
# ============================================
# - Never commit your actual .env file to version control!
# - Add .env to your .gitignore
# - For production, use environment variables or secrets manager
# - Keep your SECRET_KEY and database credentials secure
