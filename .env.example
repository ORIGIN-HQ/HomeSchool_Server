# ==============================================================================
# HOMESCHOOL API - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and update with your actual values
# Command: cp .env.example .env
# ==============================================================================

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
APP_NAME=Homeschool API
DEBUG=False
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# PostgreSQL Connection Details
POSTGRES_USER=homeschool_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD
POSTGRES_DB=homeschool_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full Database URL (constructed automatically from above values in Docker)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://homeschool_user:CHANGE_THIS_TO_A_SECURE_PASSWORD@postgres:5432/homeschool_db

# Database Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ==============================================================================
# SECURITY
# ==============================================================================

# Secret Key for JWT and session management
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ==============================================================================
# GOOGLE OAUTH AUTHENTICATION
# ==============================================================================

# Get your credentials from: https://console.cloud.google.com/apis/credentials
# Leave empty if not using Google authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==============================================================================
# DOCKER PORT CONFIGURATION (Optional)
# ==============================================================================

# Change these if you need to use different ports
BACKEND_PORT=8000
POSTGRES_EXTERNAL_PORT=5432

# ==============================================================================
# INSTRUCTIONS
# ==============================================================================
# 
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate a secure SECRET_KEY:
#    openssl rand -hex 32
#
# 3. Update these required values in .env:
#    - POSTGRES_PASSWORD (use a strong, unique password)
#    - SECRET_KEY (use the generated value from step 2)
#    - DATABASE_URL (update with your POSTGRES_PASSWORD)
#
# 4. Optional: Add Google OAuth credentials if using authentication
#    - GOOGLE_CLIENT_ID
#    - GOOGLE_CLIENT_SECRET
#
# 5. For development, you can set:
#    DEBUG=True
#    ENVIRONMENT=development
#
# 6. NEVER commit the .env file to version control!
#    It should already be in .gitignore
#
# ==============================================================================